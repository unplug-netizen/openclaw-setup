        "primary": "moonshot/kimi-for-coding"
      },
      "models": {
        "moonshot/kimi-for-coding": {},
        "kimi-coding/k2p5": {
          "alias": "Kimi for Coding"
        }
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Haupt-Agent",
        "subagents": {
          "allowAgents": [
            "coder",
            "research"
          ]
        }
      },
      {
        "id": "coder",
        "name": "Code-Assistent",
        "workspace": "/data/.openclaw/workspace/coder",
        "model": "moonshot/kimi-for-coding"
      },
      {
        "id": "research",
        "name": "research",
        "workspace": "/data/.openclaw/workspace-research",
        "agentDir": "/data/.openclaw/agents/research/agent",
        "model": "moonshot/kimi-for-coding",
        "tools": {
          "profile": "coding",
          "alsoAllow": [
            "browser",
            "message",
            "gateway",
            "tts"
          ]
        }
      }
    ]
  },
  "bindings": [
