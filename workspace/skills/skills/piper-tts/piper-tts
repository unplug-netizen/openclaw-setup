#!/bin/bash
# Piper TTS Wrapper Script
# Usage: piper-tts "Text to speak" --output output.wav

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PIPER_BIN="$SCRIPT_DIR/piper/piper"
DEFAULT_VOICE="$SCRIPT_DIR/voices/thorsten-low.onnx"

# Show help
if [ $# -eq 0 ] || [ "$1" == "--help" ] || [ "$1" == "-h" ]; then
    echo "Usage: piper-tts [OPTIONS] <text>"
    echo ""
    echo "Options:"
    echo "  --output FILE    Output WAV file (default: stdout)"
    echo "  --voice FILE     Voice model to use (default: thorsten-low)"
    echo "  --speaker NUM    Speaker ID (for multi-speaker voices)"
    echo "  --speed NUM      Speech speed (0.5-2.0, default: 1.0)"
    echo "  -h, --help       Show this help"
    echo ""
    echo "Examples:"
    echo "  piper-tts \"Hallo Welt\" --output output.wav"
    echo "  piper-tts \"Hallo Welt\" | play -"
    exit 0
fi

# Parse arguments
TEXT=""
OUTPUT=""
VOICE="$DEFAULT_VOICE"
SPEAKER=""
SPEED="1.0"

while [ $# -gt 0 ]; do
    case "$1" in
        --output)
            OUTPUT="$2"
            shift 2
            ;;
        --voice)
            VOICE="$2"
            shift 2
            ;;
        --speaker)
            SPEAKER="$2"
            shift 2
            ;;
        --speed)
            SPEED="$2"
            shift 2
            ;;
        *)
            if [ -z "$TEXT" ]; then
                TEXT="$1"
            else
                TEXT="$TEXT $1"
            fi
            shift
            ;;
    esac
done

if [ -z "$TEXT" ]; then
    echo "Error: No text provided" >&2
    exit 1
fi

if [ ! -f "$VOICE" ]; then
    echo "Error: Voice model not found: $VOICE" >&2
    exit 1
fi

# Build piper command
PIPER_ARGS="-m \"$VOICE\" --length_scale $SPEED"

if [ -n "$SPEAKER" ]; then
    PIPER_ARGS="$PIPER_ARGS -s $SPEAKER"
fi

if [ -n "$OUTPUT" ]; then
    PIPER_ARGS="$PIPER_ARGS -f \"$OUTPUT\""
else
    PIPER_ARGS="$PIPER_ARGS -f -"
fi

# Run piper
echo "$TEXT" | eval "$PIPER_BIN" $PIPER_ARGS
